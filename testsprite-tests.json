{
  "project": {
    "name": "Bearly AI Chatbot",
    "baseUrl": "https://ai-chatbot-plum-chi-39.vercel.app",
    "description": "AI Chatbot with token usage tracking, chat history, daily limits, and multiple AI models"
  },
  "auth": {
    "apiKey": "sk-user-G5HV7Qwneq43_ZA3XtvNUCYoJBGosAFlY-8AVWdFa29pPVTlTZp3ExJwC8eiJk3NjYOYJKx9tyXTNUVkNZxdxjkpOUc7oZ6MRSO-FBdnICoOQDGTOKn3EJSeo70hZtjPN-0"
  },
  "testing": {
    "framework": "playwright",
    "browser": "chromium",
    "headless": true,
    "timeout": 30000,
    "retryFailedTests": 2
  },
  "tests": [
    {
      "name": "Token Usage Tracking",
      "scenarios": [
        {
          "name": "token count increases after chat",
          "steps": [
            "navigate to app",
            "sign in with Google",
            "get initial token count from [data-testid='token-usage']",
            "fill [data-testid='chat-input'] with 'Hello'",
            "press Enter",
            "wait for [data-testid='message']",
            "get new token count",
            "assert new count > initial count"
          ]
        }
      ]
    },
    {
      "name": "Chat History",
      "scenarios": [
        {
          "name": "new chat appears in sidebar",
          "steps": [
            "navigate to app",
            "sign in",
            "fill [data-testid='chat-input'] with 'Test message'",
            "press Enter",
            "wait for [data-testid='message']",
            "assert [data-testid='sidebar'] [data-testid='chat-item'] exists"
          ]
        }
      ]
    },
    {
      "name": "Daily Limit Enforcement",
      "scenarios": [
        {
          "name": "input disables when limit exceeded",
          "steps": [
            "navigate to app",
            "sign in",
            "wait for [data-testid='limit-exceeded-banner']",
            "assert [data-testid='chat-input'] is disabled"
          ]
        }
      ]
    },
    {
      "name": "Model Switching",
      "scenarios": [
        {
          "name": "user can switch models",
          "steps": [
            "navigate to app",
            "sign in",
            "click [data-testid='model-switcher']",
            "select 'Qwen 2.5 72B'",
            "assert model changed"
          ]
        }
      ]
    }
  ]
}
